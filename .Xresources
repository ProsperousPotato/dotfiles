URxvt*boldFont: xft:DejaVu Sans Mono Nerd Font:bold:size=9,xft:DejaVuSansMono NF:pixelsize=15,xft:Everson Mono:pixelsize=15,xft:Symbola:size=10
URxvt*italicFont: xft:DejaVu Sans Mono Nerd Font:italic:autohint=true:size=9,xft:DejaVuSansMono NF:pixelsize=15,xft:Everson Mono:pixelsize=15,xft:Symbola:size=10 
URxvt*boldItalicFont: xft:DejaVu Sans Mono Nerd Font:bold:italic:autohint=true:size=9,xft:DejaVuSansMono NF:pixelsize=15,xft:Everson Mono:pixelsize=15,xft:Symbola:size=10 
URxvt.geometry: 151x39
